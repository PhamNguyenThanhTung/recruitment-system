// Cấu hình Prisma Client để tương tác với cơ sở dữ liệu
generator client {
  provider = "prisma-client-js"
}

// Cấu hình nguồn dữ liệu, sử dụng PostgreSQL và lấy URL từ biến môi trường
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 🔥 Bắt buộc cho prisma migrate với Supabase Pooler
}

// ===== ENUM =====
// Enum Role: Định nghĩa các vai trò trong hệ thống
enum Role {
  HR        // Nhân viên HR
  CANDIDATE // Ứng viên
}

// Enum JobType: Định nghĩa các loại công việc
enum JobType {
  FULL_TIME  // Toàn thời gian
  PART_TIME  // Bán thời gian
  CONTRACT   // Hợp đồng
  FREELANCE  // Freelance
  INTERNSHIP // Thực tập
}

// 1. Thêm Enum Status
enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEWING
  OFFERED
  REJECTED
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

// ===== MODELS =====

// Model User: Đại diện cho người dùng (HR hoặc Candidate) trong hệ thống
model User {
  id        String   @id @default(cuid())
  email     String   @unique             // Địa chỉ email duy nhất để đăng nhập
  password  String                        // Mật khẩu đã được mã hóa
  name      String                        // Tên người dùng
  role      Role     @default(HR)        // Vai trò: HR hoặc CANDIDATE
  phone     String?                       // Số điện thoại (tùy chọn)
  image     String?                       // Ảnh đại diện (tùy chọn)
  createdAt DateTime @default(now()) @map("created_at") // Thời điểm tạo tài khoản
  
  // Quan hệ một-nhiều với Job (một HR tạo nhiều job)
  jobs      Job[]
  // Quan hệ một-nhiều với Application (một candidate nộp nhiều đơn)
  applications Application[]
  // Quan hệ một-nhiều với SavedJob (một candidate có thể lưu nhiều job)
  savedJobs SavedJob[]

  companyProfile   CompanyProfile?
  candidateProfile CandidateProfile?

  @@map("users") // Tên bảng trong cơ sở dữ liệu là 'users'
}

// 4. Thêm/Cập nhật model CompanyProfile
model CompanyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id") // Quan hệ 1-1
  companyName String   @map("company_name")
  address     String
  website     String?
  description String?  @db.Text

  // Các trường mới Sprint 4
  logoUrl     String?  @map("logo_url")
  size        String?  // "1-10", "11-50"...
  foundedYear Int?     @map("founded_year")
  
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

// 3. Thêm/Cập nhật model CandidateProfile
model CandidateProfile {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id") // Quan hệ 1-1
  address      String?
  skills       String?  @db.Text
  bio          String?  @db.Text
  defaultCvUrl String? @map("default_cv_url") // Lưu CV mặc định để ứng tuyển nhanh 1 chạm

  // Các trường mới Sprint 4
  education    Json?    // [{ degree, school, year }]
  experience   Json?    // [{ title, company, from, to, description }]
  avatarUrl    String?  @map("avatar_url")
  
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("candidate_profiles")
}

// Model Job: Đại diện cho các tin tuyển dụng
model Job {
  id           String    @id @default(cuid())
  title        String                         // Tiêu đề công việc
  company      String                         // Tên công ty tuyển dụng
  
  description  String                         // Mô tả chi tiết công việc
  requirements String?                        // Yêu cầu công việc (tùy chọn)
  salary       String?                        // Mức lương (tùy chọn)
  // === THÊM 2 CỘT MỚI VÀO ĐÂY ===
  minSalary   Int?     // Lương tối thiểu (Lưu số: 15000000)
  maxSalary   Int?     // Lương tối đa (Lưu số: 20000000)
  companyLogoUrl String? @db.Text // Lưu đường link ảnh logo (để dấu ? vì có thể có hoặc không)
  location     String                         // Địa điểm làm việc
  jobType      JobType   @default(FULL_TIME) // Loại công việc
  deadline     DateTime?                      // Hạn chót nộp hồ sơ (tùy chọn)
  status       JobStatus @default(DRAFT)    // Trạng thái tin (Draft, Open, Closed, v.v.)
  userId       String    @map("user_id")      // ID nhân viên HR đã tạo tin này
  
  // Quan hệ với model User (một HR tạo nhiều job)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Quan hệ một-nhiều với Application
  applications Application[]
  // Quan hệ một-nhiều với SavedJob (một job có thể được lưu bởi nhiều candidate)
  savedJobs    SavedJob[]
  
  createdAt    DateTime  @default(now()) @map("created_at") // Thời điểm tạo tin

  @@map("jobs") // Tên bảng trong cơ sở dữ liệu là 'jobs'
  @@index([title])       // Đánh index cho Title
  @@index([location])    // Đánh index cho Location
  @@index([status])      // Đánh index cho Status (vì luôn lọc status = Open)
}

// 2. Sửa lại model Application (Đổi kiểu String cũ sang Enum)
model Application {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")      // ID của công việc được ứng tuyển
  userId    String   @map("user_id")     // ID của ứng viên
  cvFileUrl String   @map("cv_file_url") // URL của file CV (lưu trên Cloudinary)
  // Đổi dòng status cũ thành dòng này:
  status      ApplicationStatus @default(PENDING)
  appliedAt DateTime @default(now()) @map("applied_at") // Thời điểm nộp đơn
  
  // Quan hệ với Job (một job có nhiều application)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  // Quan hệ với User (một candidate có nhiều application)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("applications") // Tên bảng trong cơ sở dữ liệu là 'applications'
}

// Model SavedJob: Đại diện cho việc làm được lưu (bookmark) bởi ứng viên
model SavedJob {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")    // ID của ứng viên
  jobId     String   @map("job_id")     // ID của công việc được lưu
  createdAt DateTime @default(now()) @map("created_at") // Thời điểm lưu
  
  // Quan hệ với User (một candidate có thể lưu nhiều job)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Quan hệ với Job (một job có thể được lưu bởi nhiều candidate)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Đảm bảo một user không thể lưu cùng một job hai lần
  @@unique([userId, jobId])
  @@map("saved_jobs") // Tên bảng trong cơ sở dữ liệu là 'saved_jobs'
}
